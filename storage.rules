rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // User uploads - only authenticated users can upload to their own folder
    match /uploads/{userId}/{allPaths=**} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId)
        && request.resource.size < 10 * 1024 * 1024  // 10MB limit
        && request.resource.contentType.matches('image/.*|application/pdf')
        && request.resource.name.matches('.*\\.(jpg|jpeg|png|pdf)$');
    }

    // Analysis Results files - users can read/write their own analysis files
    // Works for both website and Streamlit app (when authenticated)
    match /analysis_results/{userId}/{allPaths=**} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId)
        && request.resource.size < 50 * 1024 * 1024  // 50MB limit for analysis files
        && request.resource.contentType.matches('image/.*|application/pdf|application/vnd.openxmlformats-officedocument.spreadsheetml.sheet|application/vnd.ms-excel');
    }

    // Profile pictures - users can read/write their own profile pictures
    match /profile-pictures/{userId}/{allPaths=**} {
      allow read: if isAuthenticated(); // Anyone authenticated can read (for displaying profiles)
      allow write: if isOwner(userId)
        && request.resource.size < 5 * 1024 * 1024  // 5MB limit
        && request.resource.contentType.matches('image/.*')
        && request.resource.name.matches('.*\\.(jpg|jpeg|png|webp)$');
    }

    // Public files - anyone can read
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Admin files - no client access
    match /admin/{allPaths=**} {
      allow read, write: if false;
    }

    // Reports - users can read their own reports (kept for backward compatibility)
    match /reports/{userId}/{allPaths=**} {
      allow read: if isOwner(userId);
      allow write: if false; // Only server-side functions can write
    }
  }
}
