rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper function to check if the current user is an admin
    // Admin status is stored in the users collection as isAdmin: true
    function isAdminUser() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }
    
    // Users collection - users can read/write their own profile
    // Works for both website and Streamlit app (when authenticated)
    match /users/{userId} {
      // User can read their own document
      allow read: if isOwner(userId);

      // User can create their own document during signup/onboarding
      allow create: if isAuthenticated() && request.auth.uid == userId;

      // User can update their own document
      allow update: if isOwner(userId);

      // User can delete their own document (for account deletion)
      allow delete: if isOwner(userId);
    }

    // Subscriptions collection - users can read their own subscriptions
    match /subscriptions/{subscriptionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // Only server-side functions can write
    }

    // Allow querying subscriptions by userId for active subscription lookup
    match /subscriptions {
      allow read: if request.auth != null &&
        request.query.where('userId', '==', request.auth.uid).size() == 1 &&
        request.query.where('status', 'in', ['active', 'trialing']).size() == 1 &&
        request.query.orderBy('createdAt', 'desc').size() == 1 &&
        request.query.limit().size() == 1;
    }

    // Support messages collection - users can create/read their own messages
    match /supportMessages/{messageId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // Messages are immutable once created
    }

    // Allow querying support messages filtered by userId for monthly limit checking
    match /supportMessages {
      allow read: if request.auth != null &&
        request.query.where('userId', '==', request.auth.uid).size() >= 1;
    }

    // Notifications collection - users can read/write their own notifications
    match /notifications/{notificationId} {
      allow read, update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }

    // Allow querying notifications by userId
    match /notifications {
      allow read: if request.auth != null;
    }

    // Memberships collection - users can read/write their own memberships
    match /memberships/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Analysis Results collection - users can read and create their own analysis results
    // Works for both website and Streamlit app (when authenticated)
    match /analysis_results/{resultId} {
      // Read: User can read their own analysis results, OR admin can read any
      // Support both userId (website) and user_id (AI assistant) formats
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        resource.data.user_id == request.auth.uid ||
        isAdminUser() ||
        // Allow reading if document doesn't exist yet (for create operations)
        !resource.exists
      );
      
      // Create: User can create analysis results with their own userId or user_id
      allow create: if isAuthenticated() && (
        (request.resource.data.userId != null && request.resource.data.userId == request.auth.uid) ||
        (request.resource.data.user_id != null && request.resource.data.user_id == request.auth.uid)
      );
      
      // Update/Delete: User can only modify their own analysis results
      allow update, delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        resource.data.user_id == request.auth.uid
      );
    }
    
    // Allow querying analysis_results by userId or user_id (for both website and Streamlit)
    // Note: Firestore rules have limitations checking query parameters, so we allow authenticated queries
    // Document-level rules ensure users only see their own data
    match /analysis_results {
      // Allow all authenticated users to query - document rules will filter results
      // This is necessary because Firestore rules can't easily check query.where() parameters
      // The document-level rules (above) ensure users can only read their own documents
      // We allow list operations (queries) for authenticated users
      allow list: if request.auth != null;
      allow get: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        resource.data.user_id == request.auth.uid ||
        isAdminUser() ||
        !resource.exists
      );
    }
    
    // Reports collection - kept for backward compatibility (deprecated, use analysis_results)
    match /reports/{reportId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || !resource.exists
      );
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.keys().hasAll(['userId', 'title', 'type', 'status', 'date', 'createdAt']);
      allow update, delete: if isOwner(resource.data.userId);
    }
    
    match /reports {
      allow read: if isAuthenticated() &&
        request.query.where('userId', '==', request.auth.uid).size() >= 1;
    }

    // Contacts collection - for contact form submissions (public)
    match /contacts/{contactId} {
      allow create: if true; // Anyone can submit contact forms
      allow read, write: if false; // Only admin access
    }

    // Admin-only collections (if any)
    match /admin/{document=**} {
      allow read, write: if false; // No client access
    }

    // Public collections (if any)
    match /public/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Palmira Onboarding - users can read/write their own onboarding data
    match /palmira_onboarding/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Palmira Preferences - users can read/write their own preferences
    match /palmira_preferences/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Palmira Farm Profiles - users can read/write their own farm profiles
    match /palmira_farm_profiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Palmira Chats - users can read/write their own chats
    match /palmira_chats/{chatId} {
      allow read, write: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Palmira Chat Messages - users can read/write messages in their own chats
    match /palmira_chats/{chatId}/messages/{messageId} {
      allow read, write: if isAuthenticated() && 
        get(/databases/$(database)/documents/palmira_chats/$(chatId)).data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
        get(/databases/$(database)/documents/palmira_chats/$(chatId)).data.userId == request.auth.uid;
    }

    // Allow querying Palmira chats by userId
    match /palmira_chats {
      allow read: if isAuthenticated() &&
        request.query.where('userId', '==', request.auth.uid).size() >= 1;
    }

    // Palmira Knowledge Base - read-only for authenticated users, write-only for admins (server-side)
    match /palmira_knowledge_base/{documentId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only server-side/admin access
    }

    // Allow querying Palmira knowledge base
    match /palmira_knowledge_base {
      allow read: if isAuthenticated();
    }

    // Palmira Reports - users can read their own reports (references to analysis_results)
    match /palmira_reports/{reportId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if false; // Only server-side access
    }

    // Blog Posts collection - public read access, server-side write only
    match /blog_posts/{postId} {
      // Anyone can read published blog posts
      allow read: if resource.data.published != false || !resource.exists;
      // Only server-side functions can write (via admin SDK)
      allow write: if false;
    }

    // Allow querying blog posts (public read access)
    match /blog_posts {
      // Allow public queries for published posts
      allow list: if true;
      allow get: if true;
    }

    // Newsletter Subscribers collection - server-side only
    match /newsletter_subscribers/{subscriberId} {
      // No client-side access - only server-side functions can read/write
      allow read, write: if false;
    }

    // Allow querying newsletter subscribers (server-side only)
    match /newsletter_subscribers {
      allow read, write: if false;
    }

    // Podcasts collection - server-side only (API uses admin SDK; page uses /api/podcasts)
    match /podcasts/{episodeId} {
      allow read, write: if false;
    }
    match /podcasts {
      allow read, write: if false;
    }
  }
}
